@model IReadOnlyList<EdiViewer.Models.EdiValidationErrorViewModel>

<table class="table table-sm mb-0">
    <thead class="table-secondary">
        <tr>
            <th>Severity</th>
            <th>Layer</th>
            <th>Code</th>
            <th>Segment</th>
            <th>Message</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var err in Model)
        {
            var rowClass = err.Severity == "Error" ? "table-danger" : "table-warning";
            <tr class="@rowClass">
                <td>
                    <span class="badge @(err.Severity == "Error" ? "bg-danger" : "bg-warning text-dark")">
                        @err.Severity
                    </span>
                </td>
                <td class="small text-muted">@err.Layer</td>
                <td class="font-monospace small">@err.Code</td>
                <td class="font-monospace">@(err.SegmentId ?? "—")</td>
                <td>@err.Message</td>
            </tr>
        }
    </tbody>
</table>
